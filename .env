# =============================================================================
# EASM MSSP Platform — Environment Configuration
#
# SCHNELLSTART (lokal):
#   cp .env.example .env
#   # Nur SECRET_KEY und Passwörter setzen (Pflicht)
#   make dev
#   → http://localhost:3000
#
# PRODUKTION:
#   Zusätzlich APP_DOMAIN, LETSENCRYPT_EMAIL setzen
#   make up
# =============================================================================

# ── PFLICHTFELDER ─────────────────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen — z.B.: openssl rand -hex 32
SECRET_KEY=change_me_min_64_chars_random_string_here_use_openssl_rand_hex_32

POSTGRES_USER=easm
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=easm

REDIS_PASSWORD=change_me_redis_password

# ── DOMAIN + TLS (nur für Produktion) ────────────────────────────────────────
# Lokal: diese Felder leer lassen oder beliebige Werte setzen
APP_DOMAIN=easm.cycl.group
LETSENCRYPT_EMAIL=alexander.wyrwol@me.com
DOCS_DOMAIN=docs.easm.example.de
GRAFANA_DOMAIN=grafana.easm.example.de

# ── OPTIONAL: API-KEYS (erweitern Scan-Abdeckung) ────────────────────────────
# Ohne Keys: Scans nutzen nur öffentliche Quellen (Subfinder, Naabu, Nuclei)
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
SECURITYTRAILS_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
GITHUB_TOKEN=
# Für LLM-gestützte MCP-Analyse (Schritt 2 — Optional)
ANTHROPIC_API_KEY=

# ── E-MAIL NOTIFICATIONS (optional) ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=easm-alerts@example.de
SMTP_TLS=true

# ── SLACK NOTIFICATIONS (optional) ───────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── SCAN-KONFIGURATION ────────────────────────────────────────────────────────
SCAN_CONCURRENCY=4
# Naabu Rate — bei Cloud-Hostern reduzieren (Hetzner: max 500 empfohlen)
NAABU_RATE=1000
HTTPX_SCREENSHOTS=true

# ── MONITORING ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
FLOWER_BASIC_AUTH=admin:change_me_flower_password
